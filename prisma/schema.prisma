generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  // name = firstName + " " + lastName — conservé pour rétro-compat (NextAuth session,
  // affichage profil, etc.) et maintenu en sync par l'API signup.
  name         String
  firstName    String?
  lastName     String?
  mobile       String?  // Mobile perso du négociant (saisi au signup)
  website      String?  // Site web concession (saisi au signup, optionnel)
  dealership   String?
  twilioNumber String?  // Numéro Twilio assigné au négociant — "Numéro de tracking"
  forwardPhone String?  // Numéro réel où transférer les appels — "Numéro d'atterrissage"
  role         String   @default("negotiant") // "admin" | "negotiant" | "invite" | "partenaire"
  notificationSound String  @default("cloche")   // "cloche" | "sonnette"
  soundEnabled      Boolean @default(true)
  // Marge moyenne par VO (en €). Utilisée pour les estimations de marge quand un
  // prospect vendu n'a pas de saleMargin renseignée. Obligatoire à l'inscription.
  // Default 800 pour la rétro-compat des users existants.
  averageMarginVo   Float    @default(800)
  // Mode de publication des annonces leboncoin : "manual" (négociant publie à la
  // main) ou "auto" (flux automatique depuis un DMS). Obligatoire au signup.
  publicationMode   String   @default("manual")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  prospects Prospect[]
  pushSubscriptions PushSubscription[]
  linkClicks        LinkClick[]
}

// Liens courts trackés (ex: boostervo.fr/go1, /go2, …) pour les campagnes SMS,
// emails, posts LinkedIn, etc. Chaque slug pointe vers une URL de destination
// (typiquement /app/signup) et accumule des clics.
model LinkConfig {
  id          String      @id @default(cuid())
  slug        String      @unique // "go1", "go2", … (insensible à la casse côté lookup)
  destination String      // URL relative ou absolue, ex: "/app/signup"
  label       String?     // Libellé éditable, ex: "SMS Garages Paris semaine 1"
  active      Boolean     @default(true)
  // Nombre de SMS réellement envoyés pour cette campagne, saisi manuellement
  // dans l'admin. Sert à calculer le taux de clics : visiteurs uniques / smsSent.
  smsSent     Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  clicks      LinkClick[]
}

// Un clic enregistré sur un lien court. cookieId identifie le visiteur
// (= valeur du cookie bvo_clk persistant) — plusieurs clics d'un même
// visiteur partagent le même cookieId, ce qui permet de reconstruire le
// parcours (ex: clic /go1 → clic /manuel-app → inscription).
model LinkClick {
  id            String     @id @default(cuid())
  cookieId      String     // visitor id (non unique : 1 visiteur = N clics)
  linkConfigId  String
  linkConfig    LinkConfig @relation(fields: [linkConfigId], references: [id], onDelete: Cascade)

  ip            String?
  userAgent     String?
  referer       String?
  device        String?    // "mobile" | "desktop" | "tablet"
  browser       String?    // "Chrome", "Safari", "Firefox", …
  os            String?    // "iOS", "Android", "Windows", "macOS", …

  // Attribution conversion : renseignés quand un User est créé alors que
  // le cookie bvo_clk pointait sur ce visiteur. Seul le premier clic
  // (first-touch) est marqué converti pour éviter de gonfler les stats.
  convertedAt   DateTime?
  userId        String?
  user          User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt     DateTime   @default(now())

  @@index([cookieId])
  @@index([linkConfigId])
  @@index([userId])
  @@index([createdAt])
}

model PushSubscription {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint   String   @unique
  p256dh     String   // clé publique client
  auth       String   // secret auth
  userAgent  String?  // optionnel, pour debug multi-device
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())

  @@index([userId])
}

model Prospect {
  id              String    @id @default(cuid())
  phone           String    // Numéro de l'appelant (source de vérité)
  name            String?   // Saisi après rappel
  vehicleInterest String?   // Ex: "Peugeot 3008 GT 2021"
  vehiclePrice    Float?    // Prix affiché dans l'annonce (intérêt initial)
  // Prix final négocié si la vente est conclue (statut sold).
  salePrice       Float?
  // Marge réelle faite sur cette vente (en €). Si null, on utilise user.averageMarginVo.
  saleMargin      Float?
  budget          Float?
  notes           String?
  status          String    @default("pending") // pending|postponed|unreachable|appointment|test_drive|quote_sent|not_interested|sold
  isUrgent        Boolean   @default(false)
  appointmentAt   DateTime?
  postponedUntil  DateTime? // Date de report programmé
  // Date à laquelle le prospect est passé à un statut terminal
  // (sold / appointment / test_drive / quote_sent / not_interested / unreachable).
  // Utilisé pour filtrer les stats par période (ex: ventes des 7 derniers jours).
  outcomeAt       DateTime?
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  callEvents CallEvent[]

  @@unique([phone, userId])
}

model CallEvent {
  id          String   @id @default(cuid())
  type        String   // "missed" | "answered"
  callSid     String?  // Twilio Call SID
  durationSec Int?
  ringSec     Int?
  fromPhone   String?  // Numéro appelant
  toPhone     String?  // Numéro Twilio appelé
  prospectId  String
  prospect    Prospect @relation(fields: [prospectId], references: [id])
  createdAt   DateTime @default(now())
}

// Lead capté sur la VSL "gate email" (page /vsl-prive, atteinte via le lien
// court go9). Le visiteur donne prénom + email pour débloquer la vidéo.
// cookieId = valeur du cookie bvo_clk → relie au LinkClick d'origine pour
// l'attribution. slug = lien court source (ex: "go9").
model VslLead {
  id        String   @id @default(cuid())
  firstName String
  email     String
  slug      String?
  cookieId  String?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

// Événement de lecture d'une VSL (pages /vsl et /vsl-prive). Permet de mesurer
// le taux de lecture : combien démarrent la vidéo, où ils décrochent, qui va
// jusqu'au bout. visitorId = id stable généré côté client (localStorage bvo_vid)
// → sert à dédupliquer le funnel même pour les visiteurs sans cookie bvo_clk
// (accès direct, hors lien court). cookieId/slug relient à la campagne d'origine.
model VslEvent {
  id          String   @id @default(cuid())
  visitorId   String   // id stable client (localStorage) — dédup du funnel
  cookieId    String?  // valeur du cookie bvo_clk → attribution campagne
  slug        String?  // lien court source (ex: "go9")
  page        String   // "vsl" | "vsl-prive"
  type        String   // "play" | "p25" | "p50" | "p75" | "p100"
  positionSec Float?   // position de lecture au moment de l'événement
  durationSec Float?   // durée totale de la vidéo
  createdAt   DateTime @default(now())

  @@index([visitorId])
  @@index([type])
  @@index([slug])
  @@index([createdAt])
}

// Clic sur le lien "Cliquez ici pour avoir un exemple de rapport" (home). Le
// document n'est pas encore disponible : on compte simplement l'intérêt. Une
// ligne = un clic. cookieId (= bvo_clk) permet de dériver les visiteurs uniques.
model ReportExampleClick {
  id        String   @id @default(cuid())
  cookieId  String?
  ip        String?
  userAgent String?
  source    String?  // "home" (lien dans le simulateur) ou "tarifs" (Pack Diagnostic)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([source])
}

// Demande de diagnostic (CTA "Découvrir le diagnostic" sur les pages VSL) :
// le prospect laisse prénom + email pour une présentation de 20 min. slug =
// lien court source (ex: "go9") résolu via le cookie bvo_clk. Notifié par mail.
model DiagnosticRequest {
  id        String   @id @default(cuid())
  firstName String
  email     String
  mobile    String?
  slug      String?
  cookieId  String?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

// Ouverture d'un email, captée par un pixel de tracking (image 1x1 hébergée
// sur boostervo.fr) inséré dans l'email. campaign = libellé de l'emailing
// (choisi par Max), recipient = email du destinataire si fourni via merge tag.
// 1 ligne = 1 chargement du pixel (donc potentiellement plusieurs par
// destinataire). NB: fiabilité limitée (Apple MPP gonfle, blocage images
// sous-estime) — cf. doc.
model EmailOpen {
  id        String   @id @default(cuid())
  campaign  String   // libellé de l'emailing, ex "relance-mars-2026"
  recipient String?  // email du destinataire (via merge tag), si fourni
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([campaign])
  @@index([createdAt])
}

// Visite d'une page publique de boostervo.fr (hors app). Enregistre chaque
// arrivée pour mesurer la fréquentation : visites totales, visiteurs uniques
// (dédup sur visitorId stable côté client = localStorage bvo_vid), et source
// (referer + UTM). cookieId (bvo_clk) relie à une campagne /go… si présent.
// Beacon client au chargement → /api/page-view.
model PageView {
  id          String   @id @default(cuid())
  path        String   // ex "/" (home), "/tarifs"…
  referer     String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  device      String?  // "mobile" | "desktop" | "tablet"
  browser     String?
  os          String?
  visitorId   String?  // id stable client (bvo_vid) — dédup visiteurs uniques
  cookieId    String?  // bvo_clk — attribution campagne si présent
  createdAt   DateTime @default(now())

  @@index([path])
  @@index([visitorId])
  @@index([createdAt])
}

// Lead capté par le simulateur "Combien mes appels me coûtent/rapportent"
// (pop-up de la home). Le visiteur saisit son email à la dernière étape, puis
// "Voir mon estimation" → on enregistre l'email + ses réponses + le résultat
// du calcul (gains estimés) pour qualifier le lead. slug/cookieId = attribution
// campagne via le cookie bvo_clk. Notifié par mail à l'équipe (best-effort).
model SimulatorLead {
  id        String   @id @default(cuid())
  email     String
  branch    String?  // "A" (a les stats Leboncoin) | "B" (estimation)

  // Réponses saisies
  appels             Int     // appels traités / mois
  manques            Int     // appels manqués / mois
  decrochesImmediats Int     // appels - manques
  delayLabel         String  // délai de rappel, ex "10 min"
  margeVo            Int     // marge moyenne par VO (€)

  // Résultats calculés (situation actuelle)
  convMoyenne        Float   // taux de conversion moyen pondéré
  convImmediate      Float   // taux conv décroché direct (réf.)
  convRappels        Float   // taux conv sur rappel
  ventesTotalActuel  Float
  margeTotalActuel   Int

  // Potentiel + gain
  ventesTotalPotentiel Float
  margeTotalPotentiel  Int
  gainVentesMois       Float
  gainMargeMois        Int
  gainMargeAn          Int

  slug      String?
  cookieId  String?
  source    String?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}
